generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  createdAt                DateTime                  @default(now())
  assets                   AssetLot[]
  sales                    AssetSale[]
  budgets                  Budget[]
  capitalGainsSummaries    CapitalGainsSummary[]
  capitalGainsTransactions CapitalGainsTransaction[]
  reminders                Reminder[]
  taxProfile               TaxProfile?
  transactions             Transaction[]
  wallets                  Wallet[]
}

model Wallet {
  id             String        @id @default(cuid())
  name           String
  icon           String?
  color          String?
  currency       String        @default("INR")
  openingBalance Int           @default(0)
  userId         String
  createdAt      DateTime      @default(now())
  transactions   Transaction[]
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  date        DateTime
  amount      Int
  category    String
  description String?
  source      ImportSource
  type        TransactionType
  isRecurring Boolean         @default(false)
  walletId    String
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet      Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([userId, date, amount, description])
  @@index([userId, date(sort: Desc)])
  @@index([userId, category])
  @@index([walletId])
}

model Budget {
  id          String   @id @default(cuid())
  category    String
  monthYear   String
  limitAmount Int
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, monthYear])
  @@index([userId, monthYear])
}

model AssetLot {
  id             String      @id @default(cuid())
  symbol         String
  isin           String?
  assetType      AssetType
  quantityUnits  Float
  buyPricePaise  Int
  buyDate        DateTime
  remainingUnits Float
  userId         String
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales          AssetSale[]

  @@index([userId, symbol])
  @@index([userId, buyDate])
}

model AssetSale {
  id              String    @id @default(cuid())
  symbol          String
  isin            String?
  assetType       AssetType
  quantityUnits   Float
  sellPricePaise  Int
  sellDate        DateTime
  gainType        GainType
  holdingDays     Int
  gainAmountPaise Int
  lotId           String
  userId          String
  createdAt       DateTime  @default(now())
  lot             AssetLot  @relation(fields: [lotId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sellDate])
  @@index([userId, gainType])
}

model Reminder {
  id        String       @id @default(cuid())
  title     String
  dueDate   DateTime
  amount    Int?
  type      ReminderType
  isPaid    Boolean      @default(false)
  userId    String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@index([userId, isPaid])
}

model TaxProfile {
  id            String       @id @default(cuid())
  financialYear String
  regime        TaxRegime
  taxpayerType  TaxpayerType
  incomeSource  String
  tdsDeducted   Int          @default(0)
  deductions    Json
  userId        String       @unique
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CapitalGainsTransaction {
  id                       String   @id @default(cuid())
  userId                   String
  amcName                  String
  folioNo                  String
  schemeName               String
  isin                     String?
  assetClass               String
  transactionType          String
  transactionDate          DateTime
  amount                   Float
  unitsPurchased           Float
  unitsRedeemed            Float
  unitCost                 Float
  indexedCost              Float?
  grandfatheredUnits       Float?
  grandfatheredNav         Float?
  grandfatheredValue       Float?
  shortTermGain            Float?
  longTermGainWithIndex    Float?
  longTermGainWithoutIndex Float?
  taxPercentage            Float?
  taxDeductible            Float?
  taxSurcharge             Float?
  financialYear            String
  importedAt               DateTime @default(now())
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, financialYear])
}

model CapitalGainsSummary {
  id                       String   @id @default(cuid())
  userId                   String
  financialYear            String
  assetClass               String
  period                   String
  fullValueConsideration   Float
  costOfAcquisition        Float
  shortTermGainLoss        Float
  fairMarketValue          Float?
  longTermGainWithIndex    Float
  longTermGainWithoutIndex Float
  importedAt               DateTime @default(now())
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, financialYear])
}

enum TransactionType {
  INCOME
  EXPENSE
  INVESTMENT
  TRANSFER
}

enum ImportSource {
  SPENDEE
  HDFC
  SBI
  ICICI
  AXIS
  KOTAK
  YES_BANK
  ZERODHA
  GROWW
  UPSTOX
  ANGEL_ONE
  CAMS
  KFINTECH
  MANUAL
  OTHER
  BOB
}

enum AssetType {
  STOCK
  EQUITY_MF
  DEBT_MF
  ETF
  BOND
}

enum GainType {
  STCG
  LTCG
}

enum ReminderType {
  ADVANCE_TAX
  INSURANCE_PREMIUM
  OTHER
}

enum TaxRegime {
  OLD
  NEW
}

enum TaxpayerType {
  INDIVIDUAL
  SENIOR_CITIZEN
  SUPER_SENIOR_CITIZEN
}
